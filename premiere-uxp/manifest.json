{
  "manifestVersion": 5,
  "id": "collie-video-premiere-bridge",
  "name": "Collie Video Premiere Bridge",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "26.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "collieVideoBridgePanel",
      "label": {
        "default": "Collie Video Bridge"
      },
      "minimumSize": {
        "width": 320,
        "height": 400
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 500
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 540
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request"
  }
}
